from __future__ import annotations

import html
import json
import logging
import os
import smtplib
from email.message import EmailMessage
from typing import Iterable

import requests

from .models import AlertRecord, Asset
from .utils import chunk_text

LOG = logging.getLogger(__name__)


class TelegramNotifier:
    def __init__(self, token: str, chat_id: str):
        self.token = token.strip()
        self.chat_id = str(chat_id).strip()

    @property
    def enabled(self) -> bool:
        return bool(self.token and self.chat_id)

    def send(self, text: str) -> None:
        if not self.enabled:
            LOG.warning("Telegram is not configured; alert not sent.")
            return
        url = f"https://api.telegram.org/bot{self.token}/sendMessage"
        for part in chunk_text(text, 3900):
            resp = requests.post(
                url,
                json={
                    "chat_id": self.chat_id,
                    "text": part,
                    "parse_mode": "HTML",
                    "disable_web_page_preview": False,
                },
                timeout=20,
            )
            if resp.status_code >= 400:
                raise RuntimeError(f"Telegram send failed: {resp.status_code} {resp.text[:500]}")


class DiscordNotifier:
    def __init__(self, webhook_url: str | None):
        self.webhook_url = webhook_url

    @property
    def enabled(self) -> bool:
        return bool(self.webhook_url)

    def send(self, text: str) -> None:
        if not self.webhook_url:
            return
        resp = requests.post(self.webhook_url, json={"content": text[:1900]}, timeout=20)
        if resp.status_code >= 400:
            raise RuntimeError(f"Discord send failed: {resp.status_code} {resp.text[:300]}")


class EmailNotifier:
    def __init__(self) -> None:
        self.enabled = os.getenv("EMAIL_ENABLED", "false").lower() == "true"
        self.host = os.getenv("SMTP_HOST", "")
        self.port = int(os.getenv("SMTP_PORT", "587"))
        self.user = os.getenv("SMTP_USER", "")
        self.password = os.getenv("SMTP_PASSWORD", "")
        self.to_addr = os.getenv("EMAIL_TO", "")
        self.from_addr = os.getenv("EMAIL_FROM", self.user)

    def send(self, subject: str, text: str) -> None:
        if not self.enabled:
            return
        msg = EmailMessage()
        msg["Subject"] = subject
        msg["From"] = self.from_addr
        msg["To"] = self.to_addr
        msg.set_content(text)
        with smtplib.SMTP(self.host, self.port, timeout=30) as s:
            s.starttls()
            if self.user:
                s.login(self.user, self.password)
            s.send_message(msg)


class NotifierHub:
    def __init__(self, telegram: TelegramNotifier, discord: DiscordNotifier | None = None, emailer: EmailNotifier | None = None):
        self.telegram = telegram
        self.discord = discord or DiscordNotifier(None)
        self.emailer = emailer or EmailNotifier()

    def send_alert(self, alert: AlertRecord) -> None:
        html_message = format_telegram_alert(alert)
        self.telegram.send(html_message)
        plain = strip_html(html_message)
        if self.discord.enabled:
            self.discord.send(plain)
        if self.emailer.enabled:
            self.emailer.send("Trump Market Alert", plain)

    def send_text(self, text: str) -> None:
        self.telegram.send(html.escape(text))
        if self.discord.enabled:
            self.discord.send(text)


def format_telegram_alert(alert: AlertRecord) -> str:
    d = alert.decision
    item = alert.item
    entities = d.entities
    assets: list[Asset] = []
    for h in entities:
        assets.extend(h.assets)

    if entities:
        entity_text = "\n".join(f"• {html.escape(h.name)} ({html.escape(h.kind)})" for h in entities)
    elif d.market_terms:
        entity_text = "• Market/policy topic: " + html.escape(", ".join(d.market_terms[:8]))
    else:
        entity_text = "• Unmapped market mention"

    if assets:
        asset_lines = [f"• <b>{html.escape(a.symbol)}</b> ({html.escape(a.kind)}): {html.escape(a.explanation)}" for a in assets]
        asset_text = "\n".join(asset_lines)
    else:
        asset_text = "• No direct ticker/asset mapping found."

    published = item.published_at.isoformat() if item.published_at else "Unknown"
    detected = item.detected_at.isoformat()
    quote = html.escape(d.quote or item.text[:800])
    source_line = f"{html.escape(item.platform)} - {html.escape(item.url)}" if item.url else html.escape(item.platform)

    return (
        "🚨 <b>Trump Market Alert</b>\n\n"
        "<b>Quote:</b>\n"
        f"“{quote}”\n\n"
        "<b>Source:</b>\n"
        f"{source_line}\n\n"
        "<b>Time published:</b>\n"
        f"{html.escape(published)}\n\n"
        "<b>Time detected:</b>\n"
        f"{html.escape(detected)}\n\n"
        "<b>Mentioned entity:</b>\n"
        f"{entity_text}\n\n"
        "<b>Related assets:</b>\n"
        f"{asset_text}\n\n"
        "<b>Signal:</b>\n"
        f"{html.escape(d.signal)}\n\n"
        "<b>Confidence:</b>\n"
        f"{html.escape(d.confidence)}\n\n"
        "<b>Type:</b>\n"
        f"{html.escape(d.alert_type)}\n\n"
        "<b>Reason:</b>\n"
        f"{html.escape(d.reason)}\n\n"
        "<b>Warning:</b>\n"
        "Not financial advice. Verify before trading."
    )


def strip_html(text: str) -> str:
    return text.replace("<b>", "").replace("</b>", "").replace("&amp;", "&")

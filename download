from __future__ import annotations

import argparse
import logging
import os
import sys
from datetime import datetime, timedelta, timezone
from typing import Any

from .config import AppConfig, env_bool, env_int, source_enabled
from .db import AlertDB
from .extract import decide, make_dedupe_key
from .mapping import MappingIndex
from .models import AlertRecord, SourceItem
from .notifiers import DiscordNotifier, NotifierHub, TelegramNotifier
from .sources.rss import RSSSource
from .sources.truth_social import TruthSocialSource
from .sources.x_api import XAPISource
from .sources.youtube import YouTubeSource
from .utils import clean_text, now_utc

LOG = logging.getLogger("trump_market_alert")


def configure_logging(level: str) -> None:
    logging.basicConfig(
        level=getattr(logging, level.upper(), logging.INFO),
        format="%(asctime)s %(levelname)s %(name)s - %(message)s",
    )


def build_sources(cfg: AppConfig, live_only: bool = False, text_only: bool = False):
    scfg = cfg.sources
    sources = []
    if not live_only:
        truth_cfg = scfg.get("truth_social", {}) or {}
        if source_enabled(truth_cfg, "TRUTH_SOCIAL_ENABLED", True):
            sources.append(TruthSocialSource(truth_cfg.get("accounts", []) or []))

        rss_cfg = scfg.get("rss", {}) or {}
        if source_enabled(rss_cfg, "RSS_ENABLED", True):
            sources.append(RSSSource(rss_cfg.get("feeds", []) or []))

        yt_cfg = scfg.get("youtube", {}) or {}
        if source_enabled(yt_cfg, "YOUTUBE_ENABLED", True):
            sources.append(
                YouTubeSource(
                    yt_cfg.get("channels", []) or [],
                    transcript_enabled=env_bool("YOUTUBE_TRANSCRIPT_ENABLED", bool(yt_cfg.get("transcript_enabled", True))),
                    transcript_max_age_hours=env_int("YOUTUBE_TRANSCRIPT_MAX_AGE_HOURS", int(yt_cfg.get("transcript_max_age_hours", 96))),
                )
            )

        x_cfg = scfg.get("x_api", {}) or {}
        if source_enabled(x_cfg, "X_ENABLED", False):
            sources.append(XAPISource(x_cfg.get("queries", []) or []))

    if not text_only and env_bool("LIVE_AUDIO_ENABLED", bool((scfg.get("live_audio") or {}).get("enabled", False))):
        from .sources.live_audio import LiveAudioSource

        la_cfg = scfg.get("live_audio", {}) or {}
        sources.append(
            LiveAudioSource(
                la_cfg.get("sources", []) or [],
                seconds=env_int("LIVE_AUDIO_SECONDS", int(la_cfg.get("seconds", 90))),
                model_size=os.getenv("LIVE_AUDIO_MODEL", str(la_cfg.get("model", "tiny.en"))),
            )
        )
    return sources


def should_skip_by_age(item: SourceItem, max_age_hours: int) -> bool:
    if not item.published_at:
        return False
    dt = item.published_at
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return now_utc() - dt.astimezone(timezone.utc) > timedelta(hours=max_age_hours)


def run_once(args: argparse.Namespace) -> int:
    cfg = AppConfig.load()
    configure_logging(cfg.log_level)
    db = AlertDB(cfg.database_url)
    db.init()
    mapping = MappingIndex(cfg.entities)
    hub = NotifierHub(TelegramNotifier(cfg.telegram_bot_token, cfg.telegram_chat_id), DiscordNotifier(cfg.discord_webhook_url))

    if args.sample:
        sample = SourceItem(
            source="sample",
            source_id="sample-dell-bitcoin",
            platform="Manual test",
            text="Dell is doing a great job. Bitcoin is amazing.",
            url="https://example.com/sample",
            source_type="text",
        )
        decision = decide(sample.text, mapping, sample.source_type)
        key = make_dedupe_key(sample.source, sample.source_id, decision.quote, decision.entities)
        hub.send_alert(AlertRecord(key, sample, decision))
        LOG.info("Sample alert sent.")
        return 0

    sources = build_sources(cfg, live_only=args.live_only, text_only=args.text_only)
    LOG.info("Enabled sources: %s", ", ".join(s.name for s in sources) or "none")

    total_items = 0
    new_items = 0
    alerts_sent = 0
    errors: list[str] = []

    for source in sources:
        try:
            items = source.fetch()
            LOG.info("%s returned %d item(s)", source.name, len(items))
        except Exception as exc:
            LOG.exception("Source failed: %s", source.name)
            errors.append(f"{source.name}: {exc}")
            continue

        for item in items:
            item.text = clean_text(item.text)
            if not item.text:
                continue
            total_items += 1
            if should_skip_by_age(item, cfg.max_item_age_hours):
                continue
            inserted = db.insert_raw_item(item)
            if not inserted:
                continue
            new_items += 1
            decision = decide(item.text, mapping, item.source_type)
            if not decision.should_alert:
                continue
            key = make_dedupe_key(item.source, item.source_id, decision.quote, decision.entities)
            if db.alert_exists(key):
                continue
            alert = AlertRecord(key, item, decision)
            if db.insert_alert(alert):
                try:
                    hub.send_alert(alert)
                    alerts_sent += 1
                    LOG.info("Sent alert for %s / %s", item.source, item.source_id)
                except Exception as exc:
                    LOG.exception("Failed to send alert: %s", exc)
                    errors.append(f"notify: {exc}")

    db.cleanup(cfg.cleanup_raw_days, cfg.cleanup_runs_days)
    LOG.info("Run complete: total_items=%d new_items=%d alerts_sent=%d errors=%d", total_items, new_items, alerts_sent, len(errors))
    if errors:
        _maybe_send_error_notice(db, hub, errors, cfg.error_alert_min_interval_minutes)
    return 0 if not errors else 2


def _maybe_send_error_notice(db: AlertDB, hub: NotifierHub, errors: list[str], min_interval_minutes: int) -> None:
    key = "last_error_notice_at"
    last = db.get_state(key)
    if last:
        try:
            dt = datetime.fromisoformat(last)
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
            if now_utc() - dt < timedelta(minutes=min_interval_minutes):
                return
        except Exception:
            pass
    msg = "Trump Market Alert warning:\n" + "\n".join(errors[:5])
    try:
        hub.send_text(msg)
        db.set_state(key, now_utc().isoformat())
    except Exception:
        LOG.exception("Could not send error notice")


def parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Trump Market Alert runner")
    p.add_argument("--once", action="store_true", help="Run one scan and exit")
    p.add_argument("--sample", action="store_true", help="Send a sample Telegram alert")
    p.add_argument("--live-only", action="store_true", help="Run live-audio sources only")
    p.add_argument("--text-only", action="store_true", help="Run text/RSS/API sources only")
    return p.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])
    return run_once(args)


if __name__ == "__main__":
    raise SystemExit(main())

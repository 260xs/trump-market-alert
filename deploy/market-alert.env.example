# Copy this file to /etc/market-alert.env on the always-on VM or PC.
# Put real values only in /etc/market-alert.env, never in git.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional integrations
X_BEARER_TOKEN=
DISCORD_WEBHOOK_URL=
HEALTHCHECKS_URL=

# Optional GitHub workflow dispatch from Telegram.
# Use a fine-grained token with Actions read/write access for this repo.
GITHUB_ACTIONS_TOKEN=
GITHUB_REPOSITORY=260xs/trump-market-alert
GITHUB_REF=main

# Optional always-on runner healthchecks.
# Use separate Healthchecks URLs if you want independent public/stock/candidate uptime alerts.
RUNNER_HEALTHCHECKS_URL=
STOCK_HEALTHCHECKS_URL=
CANDIDATE_HEALTHCHECKS_URL=

# Database paths on the host
SQLITE_PATH=/opt/trump-market-alert/data/market_alerts.sqlite3
STOCK_SQLITE_PATH=/opt/trump-market-alert/data/stocks.sqlite3

# Free-tier runner profile. One tiny always-on VM is enough.
RUNNER_FREE_TIER_MODE=true
RUNNER_PUBLIC_INTERVAL_SECONDS=300
RUNNER_ENABLE_STOCK_SCAN=true
RUNNER_STOCK_INTERVAL_SECONDS=3600
RUNNER_STOCK_MARKET_HOURS_ONLY=true
RUNNER_STOCK_MARKET_TIMEZONE=America/New_York
RUNNER_STOCK_MARKET_OPEN=09:30
RUNNER_STOCK_MARKET_CLOSE=16:15
# 0=Monday, 1=Tuesday, ..., 6=Sunday
RUNNER_STOCK_MARKET_DAYS=0,1,2,3,4
RUNNER_ENABLE_CANDIDATE_REFRESH=true
RUNNER_CANDIDATE_INTERVAL_SECONDS=604800
RUNNER_ENABLE_TELEGRAM_COMMANDS=true
RUNNER_LOOP_SLEEP_SECONDS=5

# Optional live audio. Keep off on free-tier VMs unless you intentionally install the heavier stack.
# If live audio is enabled, provisional alerts are limited to high-impact watched people.
ENABLE_LIVE_AUDIO=false
ENABLE_PROVISIONAL_LIVE_ALERTS=true
LIVE_MIN_MARKET_IMPACT_SCORE=9
LIVE_SAMPLE_SECONDS=90

LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
